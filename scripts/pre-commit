#!/bin/sh
# Pre-commit local: corre la guarda anti-write-back de la KB ANTES de commitear,
# para que datos de una auditoría nunca lleguen ni siquiera al historial local.
# Instalar: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
uv run scripts/check_kb_blank.py || {
  echo "pre-commit: la base ISO fue modificada (posible write-back de auditoría). Commit abortado." >&2
  exit 1
}
